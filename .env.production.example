# ──────────────────────────────────────────────────────────────────────────────
# Production .env template — copy to `.env` on the deployment server
# (or paste each KEY as a secret in your host's dashboard).
#
# Workflow:
#   scp .env.production.example your-server:/srv/rung-backend/.env
#   ssh your-server
#   nano /srv/rung-backend/.env         # fill in the blanks
#   systemctl restart rung-backend      # or whatever manages the jar
#
# The backend loads this file automatically from the working directory.
# ──────────────────────────────────────────────────────────────────────────────

SPRING_PROFILES_ACTIVE=production

# Generate once, keep a secure backup: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# Generate once, keep a secure backup: openssl rand -base64 48
JWT_SECRET=
JWT_EXP_MINUTES=120

# Managed Postgres URL (Render / Fly / Supabase / RDS)
SPRING_DATASOURCE_URL=jdbc:postgresql://PROD_HOST:5432/rungdb?sslmode=require
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Real frontend origin(s), comma-separated. No localhost in prod.
CORS_ALLOWED_ORIGINS=https://rung.app

ANTHROPIC_API_KEY=

# Email — Resend SMTP gateway. Username is literally "resend", password is
# the API key from https://resend.com/api-keys. Sending domain must be
# verified at https://resend.com/domains.
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=
MAIL_FROM=Rung <hello@rung.club>

RESET_BASE_URL=https://rung.app/reset
APP_URL=https://rung.app

APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID_MACOS=jashanveer.Rung
APNS_BUNDLE_ID_IOS=jashanveer.Rung-iOS
APNS_SANDBOX=false

PORT=8080
