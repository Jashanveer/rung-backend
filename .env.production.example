# ──────────────────────────────────────────────────────────────────────────────
# Production .env template — copy to `.env` on the deployment server
# (or paste each KEY as a secret in your host's dashboard).
#
# Workflow:
#   scp .env.production.example your-server:/srv/habit-tracker/.env
#   ssh your-server
#   nano /srv/habit-tracker/.env        # fill in the blanks
#   systemctl restart habit-tracker     # or whatever manages the jar
#
# The backend loads this file automatically from the working directory.
# ──────────────────────────────────────────────────────────────────────────────

SPRING_PROFILES_ACTIVE=production

# Generate once, keep a secure backup: openssl rand -base64 32
APP_ENCRYPTION_KEY=

# Generate once, keep a secure backup: openssl rand -base64 48
JWT_SECRET=
JWT_EXP_MINUTES=120

# Managed Postgres URL (Render / Fly / Supabase / RDS)
SPRING_DATASOURCE_URL=jdbc:postgresql://PROD_HOST:5432/habitdb?sslmode=require
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Real frontend origin(s), comma-separated. No localhost in prod.
CORS_ALLOWED_ORIGINS=https://habit-tracker.app

ANTHROPIC_API_KEY=

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=

RESET_BASE_URL=https://habit-tracker.app/reset
APP_URL=https://habit-tracker.app

APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=com.jashanveer.habit-tracker-macos
APNS_SANDBOX=false

PORT=8080
