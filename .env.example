# ──────────────────────────────────────────────────────────────────────────────
# Habit-Tracker backend — environment template
#
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# For production, set these via your hosting platform's secret manager
# (Render, Fly, Railway, AWS SSM, etc.) rather than committing a .env.
#
# Load locally:
#   ./run-local.sh                  (auto-loads .env, then runs ./mvnw spring-boot:run)
#   set -a && source .env && set +a (manual: exports every KEY=VALUE to env)
# ──────────────────────────────────────────────────────────────────────────────

# ── Spring profile ────────────────────────────────────────────────────────────
# "local" loads application-local.properties (dev defaults, ddl-auto=update).
# Set to "production" when deploying.
SPRING_PROFILES_ACTIVE=local

# ── Field-level encryption (AES-256-GCM) ──────────────────────────────────────
# Generate with: openssl rand -base64 32
# Encrypts email / PII at rest. Leave blank ONLY in dev; MUST be set in prod.
# If this value changes after data is stored, existing rows become unreadable.
APP_ENCRYPTION_KEY=

# ── JWT signing ───────────────────────────────────────────────────────────────
# Minimum 32 characters. App refuses to start in prod without this.
# Generate with: openssl rand -base64 48
JWT_SECRET=
JWT_EXP_MINUTES=120

# ── Database (Postgres) ───────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/habitdb
SPRING_DATASOURCE_USERNAME=habit_user
SPRING_DATASOURCE_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Set to your real frontend origin in prod.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# Used by the weekly insight email + AI mentor replies.
# Leave blank to disable AI features entirely (app still works; AI mentor falls
# back to static welcomes and skips auto-replies).
ANTHROPIC_API_KEY=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave MAIL_HOST blank to disable all email (password reset, verification, etc.).
# Gmail: MAIL_HOST=smtp.gmail.com / MAIL_PORT=587 / use an App Password.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@habit-tracker.app

# ── Reset links + app URL (email body links) ──────────────────────────────────
RESET_BASE_URL=https://habit-tracker.app/reset
APP_URL=https://habit-tracker.app

# ── Apple Push Notification service ───────────────────────────────────────────
# Leave blank to disable push (SSE still works in-app).
# Obtain from Apple Developer portal → Keys → create a .p8 APNs key.
# APNS_PRIVATE_KEY must contain the full .p8 file contents, newlines replaced
# with the literal two-character sequence \n (i.e. escaped newlines).
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=com.jashanveer.habit-tracker-macos
# true for local/sandbox builds, false for App Store / production builds.
APNS_SANDBOX=true

# ── Server port ───────────────────────────────────────────────────────────────
PORT=8080
